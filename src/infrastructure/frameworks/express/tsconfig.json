{
  "compilerOptions": {
      "lib": ["es5", "es6", "dom"],
      "target": "es5",
      "module": "commonjs",
      "moduleResolution": "node",
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "esModuleInterop": true,
      "paths": {
          "@domain/*": ["../../../domain/*"],
          "@application/*": ["../../../application/*"],
          "@infrastructure/*": ["../../../infrastructure/*"]
        },
        "sourceMap": true
      },
      "include": [
        "../../../../src/**/*",
        "../../../domain/**/*",
        "../../../application/**/*",
        "../../../infrastructure/**/*"
      ],
      "exclude": ["node_modules"]
  }
